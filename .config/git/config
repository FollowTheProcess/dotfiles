[user]
	name = Tom Fleet
	email = me@followtheprocess.codes
	signingkey = 667642356C177BC0

[core]
	excludesfile = ~/.config/git/ignore
	autocrlf = false
	whitespace = error
	preloadindex = true

[push]
	default = simple
	autoSetupRemote = true
	followTags = true

[pull]
	rebase = true
	default = current

[rebase]
	autoStash = true
	autoSquash = true
	updateRefs = true

[init]
	defaultBranch = main

[alias]
	st = status -s
	lol = log --oneline --graph --all

[log]
	abbrevCommit = true
	graphColors = blue,yellow,cyan,magenta,green,red

[color "decorate"]
	HEAD = red
	branch = blue
	tag = yellow
	remoteBranch = magenta

[color "branch"]
	current = magenta
	local = default
	remote = yellow
	upstream = green
	plain = blue

[diff]
    external = difft
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process

[commit]
	gpgsign = true

[tag]
	gpgsign = true

[gpg]
	program = gpg

[rerere]
	enabled = true
	autoupdate = true

[column]
	ui = auto

[branch]
	sort = -committerdate

[tags]
	sort = version:refname

[fetch]
	prune = true
	pruneTags = true
	all = true

[merge]
	conflictstyle = zdiff3

[help]
	autocorrect = prompt

[url "https://github.com/"]
	insteadOf = "git@github.com:"
	insteadOf = "ssh://git@github.com/"

[url "https://gitlab.com/"]
	insteadOf = git@gitlab.com:
	insteadOf = ssh://git@gitlab.com/

[url "https://github.com/"]
	insteadOf = "gh:"

[url "https://gitlab.com/"]
	insteadOf = "gl:"
