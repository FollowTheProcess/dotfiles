# zsh-abbr: fish-style auto-expanding abbreviations.
# Pressing space (or enter) after one of these expands it in-place, so the
# history records the full command and you see exactly what runs.
#
# Add new abbreviations with `abbr add <abbr>=<expansion>` (or edit this file
# and `exec zsh`). Erase with `abbr erase <abbr>`. See `abbr --help`.

# git
abbr "gs"="git switch"
abbr "gsc"="git switch --create"
abbr "gaa"="git add --all"
abbr "gpu"="git push"
abbr "gl"="git log --oneline"

# infrastructure
abbr "tf"="terraform"
abbr "tg"="terragrunt"
abbr "k"="kubectl"

# language tooling
abbr "build"="pyproject-build --installer=uv"
abbr "ts"="tree-sitter"
