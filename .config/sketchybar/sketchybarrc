#!/usr/bin/env lua

-- Tell Lua where to find the SbarLua C module (installed by setup.sh from source)
package.cpath = package.cpath .. ";" .. os.getenv("HOME") .. "/.local/share/sketchybar_lua/?.so"

-- Tell Lua where to find our own .lua files (any depth, via dotted require)
local config_dir = os.getenv("HOME") .. "/.config/sketchybar"
package.path = package.path .. ";" .. config_dir .. "/?.lua;" .. config_dir .. "/?/init.lua"

require("init")
