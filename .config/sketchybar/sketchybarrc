#!/usr/bin/env bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

source "$CONFIG_DIR/helpers/colors.sh"

# Bar appearance
bar=(
    position=top
    height=40
    blur_radius=30
    color="0x80${MANTLE}"
    shadow=on
    sticky=on
    padding_left=10
    padding_right=10
    notch_width=210
    margin=2
    corner_radius=8
)

sketchybar --bar "${bar[@]}"

# Defaults if not specified
default=(
    padding_left=5
    padding_right=5
    icon.font="GeistMono Nerd Font:Bold:17.0"
    label.font="GeistMono Nerd Font:Bold:14.0"
    icon.color="0xff${WHITE}"
    label.color="0xff${WHITE}"
    icon.padding_left=4
    icon.padding_right=4
    label.padding_left=4
    label.padding_right=4
)
sketchybar --default "${default[@]}"

# Every --add/--set/--subscribe redraws the bar, so accumulate everything
# into a single array and issue one sketchybar invocation at the end.
# https://felixkratz.github.io/SketchyBar/config/tricks
items=()

# Aerospace events and workspace indicators
items+=(--add event aerospace_workspace_change)

# Show the Aerospace workspaces, updates managed by the controller below so
# no subscriptions/events here.
for sid in $(aerospace list-workspaces --all); do
    items+=(
        --add item space."$sid" left
        --set space."$sid"
        icon="$sid"
        icon.padding_left=10
        icon.padding_right=6
        label.font="sketchybar-app-font:Regular:14.0"
        label.padding_left=0
        label.padding_right=10
        label.drawing=off
        background.color="0x80${SURFACE0}"
        background.corner_radius=6
        background.height=26
        background.drawing=off
        click_script="aerospace workspace $sid"
    )
done

# Hidden controller, batches up workspace change events so we don't
# have to call sketchybar N times (N = number of workspaces).
items+=(
    --add item spaces_controller left
    --set spaces_controller drawing=off updates=on
    script="$CONFIG_DIR/plugins/aerospace.sh"
    --subscribe spaces_controller aerospace_workspace_change
)

# Show when I'm in Aerospace service mode
items+=(
    --add event aerospace_mode_change
    --add item aerospace_mode left
    --subscribe aerospace_mode aerospace_mode_change
    --set aerospace_mode
    drawing=off
    label.color="0xff${PEACH}"
    icon.drawing=off
    script="$PLUGIN_DIR/aerospace_mode.sh"
)

# Show focussed app with a nice icon (uses aerospace focussed app)
items+=(
    --add item chevron left
    --set chevron icon=❯ label.drawing=off
    --add item front_app left
    --set front_app
    icon.font="sketchybar-app-font:Regular:16.0"
    icon.drawing=on
    script="$PLUGIN_DIR/front_app.sh"
    --subscribe front_app front_app_switched
)

# Clock/calendar
items+=(
    --add item clock right
    --set clock update_freq=10 icon=􀧞 icon.font="SF Pro:Bold:14.0" script="$PLUGIN_DIR/clock.sh"
)

# Volume
items+=(
    --add item volume right
    --set volume script="$PLUGIN_DIR/volume.sh"
    --subscribe volume volume_change
)

# Battery
items+=(
    --add item battery right
    --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh"
    --subscribe battery system_woke power_source_change
)

# CPU
items+=(
    --add item cpu right
    --set cpu update_freq=2 icon=􀧓 script="$PLUGIN_DIR"/cpu.sh
)

# Memory
items+=(
    --add item memory right
    --set memory update_req=2 icon=􀧖 script="$PLUGIN_DIR"/memory.sh
)

sketchybar "${items[@]}"

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$(aerospace list-workspaces --focused)"
