#!/usr/bin/env bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

source "$CONFIG_DIR/helpers/colors.sh"

# Bar appearance
bar=(
    position=top
    height=40
    blur_radius=30
    color="0x80${MANTLE}"
    shadow=on
    sticky=on
    padding_left=10
    padding_right=10
    notch_width=210
    margin=2
    corner_radius=8
)

sketchybar --bar "${bar[@]}"

# Defaults if not specified
default=(
    padding_left=5
    padding_right=5
    icon.font="GeistMono Nerd Font:Bold:17.0"
    label.font="GeistMono Nerd Font:Bold:14.0"
    icon.color="0xff${WHITE}"
    label.color="0xff${WHITE}"
    icon.padding_left=4
    icon.padding_right=4
    label.padding_left=4
    label.padding_right=4
)
sketchybar --default "${default[@]}"

# Every --add/--set/--subscribe redraws the bar, so accumulate everything
# into a single array and issue one sketchybar invocation at the end.
# https://felixkratz.github.io/SketchyBar/config/tricks
items=(
    --add event aerospace_workspace_change
    --add event bluetooth_change "com.apple.bluetooth.status"
)

# Aerospace workspace tiles are added/removed by the controller plugin below
# to track aerospace's live workspace list — see plugins/aerospace.sh. The
# final `--trigger aerospace_workspace_change` at the bottom of this file
# kicks the plugin once at startup so the bar populates from a cold start.

# Hidden controller, batches up workspace change events so we don't
# have to call sketchybar N times (N = number of workspaces).
items+=(
    --add item spaces_controller left
    --set spaces_controller drawing=off updates=on
    script="$CONFIG_DIR/plugins/aerospace.sh"
    --subscribe spaces_controller aerospace_workspace_change
)

# Show when I'm in Aerospace service mode
items+=(
    --add event aerospace_mode_change
    --add item aerospace_mode left
    --subscribe aerospace_mode aerospace_mode_change
    --set aerospace_mode
    drawing=off
    label.color="0xff${PEACH}"
    icon.drawing=off
    script="$PLUGIN_DIR/aerospace_mode.sh"
)

# Show focussed app with a nice icon (uses aerospace focussed app)
items+=(
    --add item chevron left
    --set chevron icon=❯ label.drawing=off
    --add item front_app left
    --set front_app
    icon.font="sketchybar-app-font:Regular:16.0"
    icon.drawing=on
    script="$PLUGIN_DIR/front_app.sh"
    --subscribe front_app front_app_switched
)

# Network: WiFi/VPN/offline state with IP plus live up/down throughput
items+=(
    --add item network left
    --set network update_freq=5 script="$PLUGIN_DIR/network.sh"
    --subscribe network wifi_change system_woke
    --add item network.up left
    --set network.up icon=⇡ icon.color="0xff${PEACH}" drawing=off
    --add item network.down left
    --set network.down icon=⇣ icon.color="0xff${GREEN}" drawing=off
)

# Clock/calendar
items+=(
    --add item clock right
    --set clock update_freq=30 icon=􀧞 icon.font="SF Pro:Bold:14.0" script="$PLUGIN_DIR/clock.sh"
    --subscribe clock system_woke
)

# Volume
items+=(
    --add item volume right
    --set volume script="$PLUGIN_DIR/volume.sh"
    --subscribe volume volume_change
)

# Battery
items+=(
    --add item battery right
    --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh"
    --subscribe battery system_woke power_source_change
)

# CPU
items+=(
    --add item cpu right
    --set cpu update_freq=5 icon=􀧓 script="$PLUGIN_DIR"/cpu.sh
)

# Memory
items+=(
    --add item memory right
    --set memory update_freq=5 icon=􀧖 script="$PLUGIN_DIR"/memory.sh
)

# Bluetooth audio batteries: airpods (L/R/case) and over-ear headphones.
items+=(
    --add item airpods.right right
    --set airpods.right icon=􀲍 drawing=off
    --add item airpods.case right
    --set airpods.case icon=􀹬 drawing=off
    --add item airpods.left right
    --set airpods.left icon=􀲎 drawing=off
    --add item headphones right
    --set headphones icon=􃍅 drawing=off
    --add item bluetooth_controller right
    --set bluetooth_controller drawing=off updates=on update_freq=60 script="$PLUGIN_DIR/bluetooth.sh"
    --subscribe bluetooth_controller bluetooth_change system_woke
)

sketchybar "${items[@]}"

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$(aerospace list-workspaces --focused)"
