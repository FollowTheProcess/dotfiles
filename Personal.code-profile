{"name":"Personal","icon":"terminal","settings":"{\"settings\":\"{\\n  \\\"[dockerfile]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"ms-azuretools.vscode-docker\\\"\\n  },\\n  \\\"[github-actions-workflow]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"redhat.vscode-yaml\\\",\\n    \\\"editor.indentSize\\\": \\\"tabSize\\\",\\n    \\\"editor.insertSpaces\\\": true,\\n    \\\"editor.tabSize\\\": 2\\n  },\\n  \\\"[go]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"golang.go\\\"\\n  },\\n  \\\"[json][jsonc]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"vscode.json-language-features\\\",\\n    \\\"editor.detectIndentation\\\": false,\\n    \\\"editor.indentSize\\\": \\\"tabSize\\\",\\n    \\\"editor.insertSpaces\\\": true,\\n    \\\"editor.tabSize\\\": 2\\n  },\\n  \\\"[markdown]\\\": {\\n    \\\"editor.codeActionsOnSave\\\": {\\n      \\\"source.fixAll.markdownlint\\\": \\\"explicit\\\"\\n    },\\n    \\\"editor.defaultFormatter\\\": \\\"yzhang.markdown-all-in-one\\\"\\n  },\\n  \\\"[python]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"charliermarsh.ruff\\\"\\n  },\\n  \\\"[rust]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"rust-lang.rust-analyzer\\\"\\n  },\\n  \\\"[shellscript]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"foxundermoon.shell-format\\\",\\n    \\\"files.eol\\\": \\\"auto\\\"\\n  },\\n  \\\"[toml]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"tamasfe.even-better-toml\\\",\\n    \\\"editor.formatOnSave\\\": true,\\n    \\\"editor.indentSize\\\": \\\"tabSize\\\",\\n    \\\"editor.insertSpaces\\\": true,\\n    \\\"editor.tabSize\\\": 2\\n  },\\n  \\\"[xml]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"redhat.vscode-xml\\\"\\n  },\\n  \\\"[yaml]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"redhat.vscode-yaml\\\",\\n    \\\"editor.formatOnSave\\\": true,\\n    \\\"editor.indentSize\\\": \\\"tabSize\\\",\\n    \\\"editor.insertSpaces\\\": true,\\n    \\\"editor.tabSize\\\": 2\\n  },\\n  \\\"[zig]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"ziglang.vscode-zig\\\",\\n    \\\"editor.formatOnSave\\\": true,\\n    \\\"files.eol\\\": \\\"\\\\n\\\"\\n  },\\n  \\\"advancedNewFile.convenienceOptions\\\": [\\n    \\\"current\\\",\\n    \\\"last\\\",\\n    \\\"root\\\"\\n  ],\\n  \\\"autoDocstring.docstringFormat\\\": \\\"google\\\",\\n  \\\"autoDocstring.startOnNewLine\\\": true,\\n  \\\"catppuccin.bracketMode\\\": \\\"rainbow\\\",\\n  \\\"catppuccin.italicKeywords\\\": false,\\n  \\\"catppuccin.workbenchMode\\\": \\\"flat\\\",\\n  \\\"chat.commandCenter.enabled\\\": false,\\n  \\\"editor.acceptSuggestionOnEnter\\\": \\\"on\\\",\\n  \\\"editor.accessibilitySupport\\\": \\\"off\\\",\\n  \\\"editor.autoClosingBrackets\\\": \\\"languageDefined\\\",\\n  \\\"editor.autoClosingOvertype\\\": \\\"auto\\\",\\n  \\\"editor.autoClosingQuotes\\\": \\\"languageDefined\\\",\\n  \\\"editor.bracketPairColorization.enabled\\\": true,\\n  \\\"editor.codeActionsOnSave\\\": {\\n    \\\"source.fixAll\\\": \\\"explicit\\\",\\n    \\\"source.organizeImports\\\": \\\"explicit\\\"\\n  },\\n  \\\"editor.codeLens\\\": true,\\n  \\\"editor.cursorBlinking\\\": \\\"phase\\\",\\n  \\\"editor.cursorSmoothCaretAnimation\\\": \\\"on\\\",\\n  \\\"editor.cursorStyle\\\": \\\"line-thin\\\",\\n  \\\"editor.defaultColorDecorators\\\": \\\"auto\\\",\\n  \\\"editor.fontFamily\\\": \\\"SF Mono\\\",\\n  \\\"editor.fontLigatures\\\": \\\"'calt', 'liga', 'dlig', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08'\\\",\\n  \\\"editor.fontSize\\\": 12,\\n  \\\"editor.fontWeight\\\": \\\"normal\\\",\\n  \\\"editor.formatOnSave\\\": true,\\n  \\\"editor.guides.bracketPairs\\\": \\\"active\\\",\\n  \\\"editor.guides.bracketPairsHorizontal\\\": \\\"active\\\",\\n  \\\"editor.hover.sticky\\\": true,\\n  \\\"editor.inlineSuggest.enabled\\\": true,\\n  \\\"editor.linkedEditing\\\": true,\\n  \\\"editor.minimap.enabled\\\": false,\\n  \\\"editor.minimap.renderCharacters\\\": false,\\n  \\\"editor.occurrencesHighlight\\\": \\\"singleFile\\\",\\n  \\\"editor.parameterHints.enabled\\\": true,\\n  \\\"editor.semanticHighlighting.enabled\\\": true,\\n  \\\"editor.suggestSelection\\\": \\\"first\\\",\\n  \\\"editor.tokenColorCustomizations\\\": {\\n    \\\"[Ariake Dark]\\\": {\\n      \\\"textMateRules\\\": [\\n        {\\n          \\\"scope\\\": [\\n            \\\"string\\\"\\n          ],\\n          \\\"settings\\\": {\\n            \\\"foreground\\\": \\\"#3cecc6e7\\\"\\n          }\\n        }\\n      ]\\n    },\\n    \\\"[Catppuccin Macchiato][Catppuccin Frappé][Catppuccin Mocha]\\\": {\\n      \\\"textMateRules\\\": [\\n        {\\n          \\\"scope\\\": [\\n            \\\"entity.name.namespace\\\"\\n          ],\\n          \\\"settings\\\": {\\n            \\\"foreground\\\": \\\"#a1e7f2ef\\\"\\n          }\\n        },\\n        {\\n          \\\"scope\\\": [\\n            \\\"entity.name.type\\\"\\n          ],\\n          \\\"settings\\\": {\\n            \\\"foreground\\\": \\\"#ffebc4e4\\\"\\n          }\\n        },\\n        {\\n          \\\"scope\\\": [\\n            \\\"string\\\",\\n            \\\"punctuation.definition.string.begin\\\",\\n            \\\"punctuation.definition.string.end\\\"\\n          ],\\n          \\\"settings\\\": {\\n            \\\"foreground\\\": \\\"#a1e7f2ef\\\"\\n          }\\n        }\\n      ]\\n    },\\n    \\\"[Tokyo Night][Tokyo Night Storm]\\\": {\\n      \\\"textMateRules\\\": [\\n        {\\n          \\\"scope\\\": [\\n            \\\"string\\\"\\n          ],\\n          \\\"settings\\\": {\\n            \\\"foreground\\\": \\\"#77f6dae7\\\"\\n          }\\n        }\\n      ]\\n    },\\n    \\\"textMateRules\\\": [\\n      {\\n        \\\"name\\\": \\\"Comment\\\",\\n        \\\"scope\\\": [\\n          \\\"comment\\\",\\n          \\\"comment.block\\\",\\n          \\\"comment.block.documentation\\\",\\n          \\\"comment.line\\\",\\n          \\\"comment.line.double-slash\\\",\\n          \\\"punctuation.definition.comment\\\"\\n        ],\\n        \\\"settings\\\": {\\n          \\\"fontStyle\\\": \\\"italic\\\"\\n        }\\n      }\\n    ]\\n  },\\n  \\\"editor.wordSeparators\\\": \\\"`~!@#$%^&*()=+[{]}\\\\\\\\|;:'\\\\\\\",.<>/?\\\",\\n  \\\"editor.wordWrap\\\": \\\"on\\\",\\n  \\\"errorLens.alignMessage\\\": {\\n    \\\"end\\\": 0,\\n    \\\"minimumMargin\\\": 10,\\n    \\\"start\\\": 40\\n  },\\n  \\\"errorLens.delayMode\\\": \\\"debounce\\\",\\n  \\\"errorLens.margin\\\": \\\"8ch\\\",\\n  \\\"errorLens.messageBackgroundMode\\\": \\\"none\\\",\\n  \\\"errorLens.messageMaxChars\\\": 200,\\n  \\\"evenBetterToml.formatter.arrayAutoCollapse\\\": false,\\n  \\\"evenBetterToml.formatter.compactArrays\\\": false,\\n  \\\"evenBetterToml.schema.associations\\\": {\\n    \\\"Cargo.toml\\\": \\\"https://json.schemastore.org/cargo.json\\\",\\n    \\\"pyproject.toml\\\": \\\"https://json.schemastore.org/pyproject.json\\\"\\n  },\\n  \\\"evenBetterToml.schema.enabled\\\": true,\\n  \\\"evenBetterToml.semanticTokens\\\": true,\\n  \\\"explorer.compactFolders\\\": false,\\n  \\\"explorer.excludeGitIgnore\\\": false,\\n  \\\"files.associations\\\": {\\n    \\\"*.json5\\\": \\\"jsonc\\\",\\n    \\\"*.plist\\\": \\\"xml\\\",\\n    \\\"*.sarif\\\": \\\"json\\\",\\n    \\\"*.slide\\\": \\\"markdown\\\",\\n    \\\".yamllint\\\": \\\"yaml\\\",\\n    \\\"justfile\\\": \\\"just\\\",\\n    \\\"requirements*.in\\\": \\\"pip-requirements\\\",\\n    \\\"requirements*.txt\\\": \\\"pip-requirements\\\",\\n    \\\"uv.lock\\\": \\\"toml\\\"\\n  },\\n  \\\"files.defaultLanguage\\\": \\\"${activeEditorLanguage}\\\",\\n  \\\"files.exclude\\\": {\\n    \\\"**/*.egg-info\\\": true,\\n    \\\"**/.DS_Store\\\": true,\\n    \\\"**/.git\\\": true,\\n    \\\"**/.hg\\\": true,\\n    \\\"**/.ipynb_checkpoints\\\": true,\\n    \\\"**/.mypy_cache\\\": true,\\n    \\\"**/.nox\\\": true,\\n    \\\"**/.pytest_cache\\\": true,\\n    \\\"**/.ruff_cache\\\": true,\\n    \\\"**/.svn\\\": true,\\n    \\\"**/.tox\\\": true,\\n    \\\"**/CVS\\\": true,\\n    \\\"**/__pycache__\\\": true\\n  },\\n  \\\"git.autofetch\\\": true,\\n  \\\"git.confirmSync\\\": false,\\n  \\\"git.enableCommitSigning\\\": true,\\n  \\\"git.openRepositoryInParentFolders\\\": \\\"never\\\",\\n  \\\"githubPullRequests.pullBranch\\\": \\\"never\\\",\\n  \\\"gitlens.advanced.messages\\\": {\\n    \\\"suppressIntegrationRequestTimedOutWarning\\\": true\\n  },\\n  \\\"gitlens.autolinks\\\": [\\n    {\\n      \\\"prefix\\\": \\\"POD-\\\",\\n      \\\"url\\\": \\\"https://chetwood.atlassian.net/browse/POD-<num>\\\"\\n    }\\n  ],\\n  \\\"gitlens.showWhatsNewAfterUpgrades\\\": false,\\n  \\\"go.addTags\\\": {\\n    \\\"promptForTags\\\": false,\\n    \\\"tags\\\": \\\"json\\\",\\n    \\\"transform\\\": \\\"camelcase\\\"\\n  },\\n  \\\"go.lintFlags\\\": [\\n    \\\"--fast\\\"\\n  ],\\n  \\\"go.lintTool\\\": \\\"golangci-lint\\\",\\n  \\\"go.toolsManagement.autoUpdate\\\": true,\\n  \\\"go.useLanguageServer\\\": true,\\n  \\\"gopls\\\": {\\n    \\\"analyses\\\": {\\n      \\\"nilness\\\": true,\\n      \\\"shadow\\\": true,\\n      \\\"staticcheck\\\": true,\\n      \\\"unusedparams\\\": false,\\n      \\\"unusedwrite\\\": true,\\n      \\\"useany\\\": true\\n    },\\n    \\\"formatting.gofumpt\\\": true,\\n    \\\"ui.codelenses\\\": {\\n      \\\"gc_details\\\": true,\\n      \\\"generate\\\": true\\n    },\\n    \\\"ui.completion.usePlaceholders\\\": false,\\n    \\\"ui.documentation.hoverKind\\\": \\\"FullDocumentation\\\",\\n    \\\"ui.semanticTokens\\\": true\\n  },\\n  \\\"html.autoClosingTags\\\": true,\\n  \\\"javascript.format.semicolons\\\": \\\"insert\\\",\\n  \\\"markdownlint.config\\\": {\\n    \\\"MD001\\\": false,\\n    \\\"MD010\\\": false,\\n    \\\"MD028\\\": false,\\n    \\\"MD033\\\": false,\\n    \\\"MD036\\\": false,\\n    \\\"MD041\\\": false,\\n    \\\"MD046\\\": false\\n  },\\n  \\\"mypy-type-checker.args\\\": [\\n    \\\"--config-file=pyproject.toml\\\"\\n  ],\\n  \\\"mypy-type-checker.importStrategy\\\": \\\"fromEnvironment\\\",\\n  \\\"notebook.cellToolbarLocation\\\": {\\n    \\\"default\\\": \\\"right\\\",\\n    \\\"jupyter-notebook\\\": \\\"left\\\"\\n  },\\n  \\\"python.analysis.autoImportCompletions\\\": true,\\n  \\\"python.analysis.completeFunctionParens\\\": false,\\n  \\\"python.analysis.diagnosticMode\\\": \\\"openFilesOnly\\\",\\n  \\\"python.analysis.typeCheckingMode\\\": \\\"strict\\\",\\n  \\\"python.languageServer\\\": \\\"Pylance\\\",\\n  \\\"python.terminal.activateEnvInCurrentTerminal\\\": true,\\n  \\\"python.terminal.activateEnvironment\\\": true,\\n  \\\"redhat.telemetry.enabled\\\": false,\\n  \\\"ruff.fixAll\\\": true,\\n  \\\"ruff.importStrategy\\\": \\\"fromEnvironment\\\",\\n  \\\"ruff.nativeServer\\\": true,\\n  \\\"ruff.organizeImports\\\": true,\\n  \\\"ruff.showSyntaxErrors\\\": false,\\n  \\\"rust-analyzer.cargo.allTargets\\\": true,\\n  \\\"rust-analyzer.check.allTargets\\\": true,\\n  \\\"rust-analyzer.check.command\\\": \\\"clippy\\\",\\n  \\\"rust-analyzer.check.extraArgs\\\": [\\n    \\\"--all-features\\\"\\n  ],\\n  \\\"rust-analyzer.imports.group.enable\\\": true,\\n  \\\"rust-analyzer.inlayHints.closingBraceHints.enable\\\": false,\\n  \\\"search.exclude\\\": {\\n    \\\"**/*.code-search\\\": true,\\n    \\\"**/*.venv\\\": true,\\n    \\\"**/*venv\\\": true,\\n    \\\"**/bower_components\\\": true,\\n    \\\"**/lib\\\": true,\\n    \\\"**/node_modules\\\": true\\n  },\\n  \\\"security.workspace.trust.untrustedFiles\\\": \\\"open\\\",\\n  \\\"shellformat.effectLanguages\\\": [\\n    \\\"shellscript\\\",\\n    \\\"hosts\\\",\\n    \\\"jvmoptions\\\",\\n    \\\"spring-boot-properties\\\",\\n    \\\"azcli\\\"\\n  ],\\n  \\\"terminal.integrated.cursorBlinking\\\": true,\\n  \\\"terminal.integrated.cursorStyle\\\": \\\"line\\\",\\n  \\\"terminal.integrated.enablePersistentSessions\\\": false,\\n  \\\"terminal.integrated.fontFamily\\\": \\\"SFMono Nerd Font\\\",\\n  \\\"terminal.integrated.fontLigatures\\\": true,\\n  \\\"terminal.integrated.fontSize\\\": 12,\\n  \\\"todo-tree.filtering.ignoreGitSubmodules\\\": true,\\n  \\\"todo-tree.filtering.useBuiltInExcludes\\\": \\\"file and search excludes\\\",\\n  \\\"todo-tree.general.showActivityBarBadge\\\": false,\\n  \\\"todo-tree.general.tags\\\": [\\n    \\\"FIXME\\\",\\n    \\\"BUG\\\",\\n    \\\"TODO\\\",\\n    \\\"todo!\\\"\\n  ],\\n  \\\"todo-tree.highlights.customHighlight\\\": {\\n    \\\"BUG\\\": {\\n      \\\"fontStyle\\\": \\\"italic\\\",\\n      \\\"foreground\\\": \\\"#e87b7b\\\",\\n      \\\"gutterIcon\\\": true,\\n      \\\"type\\\": \\\"tag-and-comment\\\"\\n    },\\n    \\\"FIXME\\\": {\\n      \\\"fontStyle\\\": \\\"italic\\\",\\n      \\\"foreground\\\": \\\"#e8ae7b\\\",\\n      \\\"gutterIcon\\\": true,\\n      \\\"type\\\": \\\"tag-and-comment\\\"\\n    },\\n    \\\"TODO\\\": {\\n      \\\"fontStyle\\\": \\\"italic\\\",\\n      \\\"foreground\\\": \\\"#7ddbec\\\",\\n      \\\"gutterIcon\\\": true,\\n      \\\"type\\\": \\\"tag-and-comment\\\"\\n    },\\n    \\\"todo!\\\": {\\n      \\\"foreground\\\": \\\"#F5FAFF\\\",\\n      \\\"gutterIcon\\\": true\\n    }\\n  },\\n  \\\"todo-tree.highlights.enabled\\\": true,\\n  \\\"todo-tree.regex.regex\\\": \\\"(//|#|<!--|;|/\\\\\\\\*|^|^\\\\\\\\s*(-|\\\\\\\\d+.))\\\\\\\\s*($TAGS)\\\",\\n  \\\"todo-tree.tree.expanded\\\": false,\\n  \\\"todo-tree.tree.flat\\\": false,\\n  \\\"todo-tree.tree.tagsOnly\\\": true,\\n  \\\"typescript.format.semicolons\\\": \\\"insert\\\",\\n  \\\"vsintellicode.java.completionsEnabled\\\": false,\\n  \\\"vsintellicode.typescript.completionsEnabled\\\": true,\\n  \\\"workbench.colorCustomizations\\\": {\\n    \\\"[Catppuccin Macchiato][Catppuccin Frappé][Catppuccin Mocha]\\\": {\\n      \\\"editorBracketHighlight.foreground1\\\": \\\"#ABBFF2\\\",\\n      \\\"editorBracketHighlight.foreground2\\\": \\\"#F993BA\\\",\\n      \\\"editorBracketHighlight.foreground3\\\": \\\"#DDA3F7\\\",\\n      \\\"editorBracketHighlight.foreground4\\\": \\\"#D3B2FF\\\",\\n      \\\"editorBracketHighlight.foreground5\\\": \\\"#B6D5F3\\\",\\n      \\\"editorBracketHighlight.foreground6\\\": \\\"#9AEFEA\\\",\\n      \\\"editorBracketHighlight.unexpectedBracket.foreground\\\": \\\"#F1487B\\\",\\n      \\\"editorError.foreground\\\": \\\"#fc93b086\\\",\\n      \\\"editorInfo.foreground\\\": \\\"#00e5ff6e\\\",\\n      \\\"editorInlayHint.background\\\": \\\"#00171900\\\",\\n      \\\"editorInlayHint.foreground\\\": \\\"#9AEFEA\\\",\\n      \\\"editorWarning.foreground\\\": \\\"#f6bd974c\\\"\\n    }\\n  },\\n  \\\"workbench.colorTheme\\\": \\\"Catppuccin Mocha\\\",\\n  \\\"workbench.editor.enablePreview\\\": false,\\n  \\\"workbench.editor.languageDetection\\\": false,\\n  \\\"workbench.fontAliasing\\\": \\\"auto\\\",\\n  \\\"workbench.iconTheme\\\": \\\"catppuccin-mocha\\\",\\n  \\\"workbench.settings.editor\\\": \\\"json\\\",\\n  \\\"workbench.settings.openDefaultSettings\\\": true,\\n  \\\"workbench.settings.useSplitJSON\\\": true,\\n  \\\"workbench.startupEditor\\\": \\\"none\\\",\\n  \\\"zig.zls.warnStyle\\\": true\\n}\"}","keybindings":"{\"keybindings\":\"// Place your key bindings in this file to override the defaults\\n[\\n    {\\n        \\\"key\\\": \\\"cmd+n\\\",\\n        \\\"command\\\": \\\"extension.advancedNewFile\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+n\\\",\\n        \\\"command\\\": \\\"-extension.advancedNewFile\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"cmd+]\\\",\\n        \\\"command\\\": \\\"editor.action.blockComment\\\",\\n        \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+alt+a\\\",\\n        \\\"command\\\": \\\"-editor.action.blockComment\\\",\\n        \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n    }\\n]\",\"platform\":1}","snippets":"{\"snippets\":{\"Tom.code-snippets\":\"{\\n\\t// Place your global snippets here. Each snippet is defined under a snippet name and has a scope, prefix, body and \\n\\t// description. Add comma separated ids of the languages where the snippet is applicable in the scope field. If scope \\n\\t// is left empty or omitted, the snippet gets applied to all languages. The prefix is what is \\n\\t// used to trigger the snippet and the body will be expanded and inserted. Possible variables are: \\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. \\n\\t// Placeholders with the same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"scope\\\": \\\"javascript,typescript\\\",\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"TODO\\\": {\\n\\t\\t\\\"prefix\\\": \\\"todo\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"$LINE_COMMENT TODO(@FollowTheProcess): $0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a comment: TODO.\\\"\\n\\t},\\n\\t\\\"FIXME\\\": {\\n\\t\\t\\\"prefix\\\": \\\"fixme\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"$LINE_COMMENT FIXME: $0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a comment: FIXME.\\\"\\n\\t},\\n\\t\\\"BUG\\\": {\\n\\t\\t\\\"prefix\\\": \\\"bug\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"$LINE_COMMENT BUG: $0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a comment: BUG.\\\"\\n\\t}\\n}\",\"rust.json\":\"{\\n\\t// Place your snippets for rust here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"Derive\\\": {\\n\\t\\t\\\"prefix\\\": \\\"derive\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[derive($1)]$0\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Insert a derive macro\\\"\\n\\t},\\n\\t\\\"Config\\\": {\\n\\t\\t\\\"prefix\\\": \\\"cfg\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[cfg($1)]\\\",\\n\\t\\t\\t\\\"$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a generic config setting\\\"\\n\\t},\\n\\t\\\"Config Test\\\": {\\n\\t\\t\\\"prefix\\\": \\\"tests\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[cfg(test)]\\\",\\n\\t\\t\\t\\\"mod test {\\\",\\n\\t\\t\\t\\\"\\\\tuse super::*;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"\\\\t#[test]\\\",\\n\\t\\t\\t\\\"\\\\tfn $1() {\\\",\\n\\t\\t\\t\\\"\\\\t\\\\t$0;\\\",\\n\\t\\t\\t\\\"\\\\t}\\\",\\n\\t\\t\\t\\\"}\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Adds a test group\\\"\\n\\t},\\n\\t\\\"Test\\\": {\\n\\t\\t\\\"prefix\\\": \\\"test\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[test]\\\",\\n\\t\\t\\t\\\"fn $1() {\\\",\\n\\t\\t\\t\\\"\\\\t$0;\\\",\\n\\t\\t\\t\\\"}\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Adds a single unit test\\\"\\n\\t},\\n\\t\\\"Clap\\\": {\\n\\t\\t\\\"prefix\\\": \\\"clap\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[clap($1)]\\\",\\n\\t\\t\\t\\\"$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a generic clap macro statement\\\"\\n\\t},\\n\\t\\\"Command\\\": {\\n\\t\\t\\\"prefix\\\": \\\"command\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[command($1)]\\\",\\n\\t\\t\\t\\\"$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a clap command macro statement\\\"\\n\\t},\\n\\t\\\"Arg\\\": {\\n\\t\\t\\\"prefix\\\": \\\"arg\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[arg($1)]\\\",\\n\\t\\t\\t\\\"$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a clap arg macro statement\\\"\\n\\t},\\n\\t\\\"C