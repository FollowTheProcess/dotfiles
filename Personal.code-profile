{"name":"Personal","settings":"{\"settings\":\"{\\n  \\\"[dockerfile]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"ms-azuretools.vscode-docker\\\"\\n  },\\n  \\\"[dotenv]\\\": {\\n    \\\"editor.formatOnSave\\\": false\\n  },\\n  \\\"[go]\\\": {\\n    \\\"editor.codeActionsOnSave\\\": {\\n      \\\"source.fixAll\\\": true,\\n      \\\"source.organizeImports\\\": true\\n    },\\n    \\\"editor.defaultFormatter\\\": \\\"golang.go-nightly\\\"\\n  },\\n  \\\"[json]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"vscode.json-language-features\\\"\\n  },\\n  \\\"[jsonc]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"vscode.json-language-features\\\"\\n  },\\n  \\\"[markdown]\\\": {\\n    \\\"editor.codeActionsOnSave\\\": {\\n      \\\"source.fixAll.markdownlint\\\": true\\n    },\\n    \\\"editor.defaultFormatter\\\": \\\"yzhang.markdown-all-in-one\\\",\\n    \\\"editor.formatOnSave\\\": false\\n  },\\n  \\\"[python]\\\": {\\n    \\\"editor.autoClosingBrackets\\\": \\\"languageDefined\\\",\\n    \\\"editor.autoClosingQuotes\\\": \\\"languageDefined\\\",\\n    \\\"editor.codeActionsOnSave\\\": {\\n      \\\"source.fixAll\\\": true,\\n      \\\"source.organizeImports\\\": true\\n    },\\n    \\\"editor.defaultFormatter\\\": \\\"ms-python.black-formatter\\\",\\n    \\\"editor.formatOnSave\\\": true,\\n    \\\"editor.formatOnSaveMode\\\": \\\"file\\\",\\n    \\\"editor.formatOnType\\\": true\\n  },\\n  \\\"[rust]\\\": {\\n    \\\"editor.codeActionsOnSave\\\": {\\n      \\\"source.fixAll\\\": true,\\n      \\\"source.organizeImports\\\": true\\n    },\\n    \\\"editor.defaultFormatter\\\": \\\"rust-lang.rust-analyzer\\\"\\n  },\\n  \\\"[shellscript]\\\": {\\n    \\\"editor.codeActionsOnSave\\\": {\\n      \\\"source.fixAll\\\": true\\n    },\\n    \\\"editor.defaultFormatter\\\": \\\"foxundermoon.shell-format\\\",\\n    \\\"files.eol\\\": \\\"auto\\\"\\n  },\\n  \\\"[yaml]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"redhat.vscode-yaml\\\"\\n  },\\n  \\\"advancedNewFile.convenienceOptions\\\": [\\n    \\\"current\\\",\\n    \\\"last\\\",\\n    \\\"root\\\"\\n  ],\\n  \\\"autoDocstring.docstringFormat\\\": \\\"google\\\",\\n  \\\"autoDocstring.startOnNewLine\\\": true,\\n  \\\"black-formatter.args\\\": [\\n    \\\"--preview\\\"\\n  ],\\n  \\\"editor.acceptSuggestionOnEnter\\\": \\\"on\\\",\\n  \\\"editor.autoClosingOvertype\\\": \\\"auto\\\",\\n  \\\"editor.bracketPairColorization.enabled\\\": true,\\n  \\\"editor.codeLens\\\": true,\\n  \\\"editor.cursorBlinking\\\": \\\"phase\\\",\\n  \\\"editor.cursorSmoothCaretAnimation\\\": \\\"on\\\",\\n  \\\"editor.cursorStyle\\\": \\\"line-thin\\\",\\n  \\\"editor.fontFamily\\\": \\\"SF Mono\\\",\\n  \\\"editor.fontLigatures\\\": true,\\n  \\\"editor.fontSize\\\": 12,\\n  \\\"editor.fontWeight\\\": \\\"normal\\\",\\n  \\\"editor.formatOnSave\\\": true,\\n  \\\"editor.guides.bracketPairs\\\": \\\"active\\\",\\n  \\\"editor.guides.bracketPairsHorizontal\\\": \\\"active\\\",\\n  \\\"editor.hover.sticky\\\": true,\\n  \\\"editor.inlineSuggest.enabled\\\": true,\\n  \\\"editor.linkedEditing\\\": true,\\n  \\\"editor.minimap.enabled\\\": false,\\n  \\\"editor.minimap.renderCharacters\\\": false,\\n  \\\"editor.occurrencesHighlight\\\": false,\\n  \\\"editor.parameterHints.enabled\\\": true,\\n  \\\"editor.semanticHighlighting.enabled\\\": true,\\n  \\\"editor.suggestSelection\\\": \\\"first\\\",\\n  \\\"editor.tokenColorCustomizations\\\": {\\n    \\\"[Ariake Dark]\\\": {\\n      \\\"textMateRules\\\": [\\n        {\\n          \\\"scope\\\": [\\n            \\\"string\\\"\\n          ],\\n          \\\"settings\\\": {\\n            \\\"foreground\\\": \\\"#3cecc6e7\\\"\\n          }\\n        }\\n      ]\\n    },\\n    \\\"textMateRules\\\": [\\n      {\\n        \\\"name\\\": \\\"Comment\\\",\\n        \\\"scope\\\": [\\n          \\\"comment\\\",\\n          \\\"comment.block\\\",\\n          \\\"comment.block.documentation\\\",\\n          \\\"comment.line\\\",\\n          \\\"comment.line.double-slash\\\",\\n          \\\"punctuation.definition.comment\\\"\\n        ],\\n        \\\"settings\\\": {\\n          \\\"fontStyle\\\": \\\"italic\\\"\\n        }\\n      }\\n    ]\\n  },\\n  \\\"editor.wordWrap\\\": \\\"on\\\",\\n  \\\"evenBetterToml.formatter.arrayAutoCollapse\\\": true,\\n  \\\"evenBetterToml.formatter.compactArrays\\\": true,\\n  \\\"evenBetterToml.schema.associations\\\": {\\n    \\\"Cargo.toml\\\": \\\"https://json.schemastore.org/cargo.json\\\",\\n    \\\"pyproject.toml\\\": \\\"https://json.schemastore.org/pyproject.json\\\"\\n  },\\n  \\\"evenBetterToml.schema.enabled\\\": true,\\n  \\\"evenBetterToml.semanticTokens\\\": true,\\n  \\\"explorer.compactFolders\\\": false,\\n  \\\"explorer.excludeGitIgnore\\\": false,\\n  \\\"files.associations\\\": {\\n    \\\"*.slide\\\": \\\"markdown\\\",\\n    \\\".yamllint\\\": \\\"yaml\\\",\\n    \\\"justfile\\\": \\\"just\\\",\\n    \\\"requirements*.in\\\": \\\"pip-requirements\\\",\\n    \\\"requirements*.txt\\\": \\\"pip-requirements\\\"\\n  },\\n  \\\"files.defaultLanguage\\\": \\\"${activeEditorLanguage}\\\",\\n  \\\"files.exclude\\\": {\\n    \\\"**/*.egg-info\\\": true,\\n    \\\"**/.DS_Store\\\": true,\\n    \\\"**/.git\\\": true,\\n    \\\"**/.hg\\\": true,\\n    \\\"**/.ipynb_checkpoints\\\": true,\\n    \\\"**/.mypy_cache\\\": true,\\n    \\\"**/.nox\\\": true,\\n    \\\"**/.pytest_cache\\\": true,\\n    \\\"**/.svn\\\": true,\\n    \\\"**/.tox\\\": true,\\n    \\\"**/CVS\\\": true,\\n    \\\"**/__pycache__\\\": true\\n  },\\n  \\\"flake8.args\\\": [\\n    \\\"--max-line-length=120\\\",\\n    \\\"--extend-ignore=E203,W503\\\"\\n  ],\\n  \\\"git.autofetch\\\": true,\\n  \\\"git.confirmSync\\\": true,\\n  \\\"git.enableCommitSigning\\\": true,\\n  \\\"github.copilot.enable\\\": {\\n    \\\"*\\\": true,\\n    \\\"markdown\\\": true,\\n    \\\"plaintext\\\": false,\\n    \\\"yaml\\\": true\\n  },\\n  \\\"githubPullRequests.pullBranch\\\": \\\"prompt\\\",\\n  \\\"gitlens.showWelcomeOnInstall\\\": false,\\n  \\\"gitlens.showWhatsNewAfterUpgrades\\\": false,\\n  \\\"go.inlayHints.compositeLiteralFields\\\": true,\\n  \\\"go.inlayHints.constantValues\\\": true,\\n  \\\"go.lintFlags\\\": [\\n    \\\"--fast\\\"\\n  ],\\n  \\\"go.lintTool\\\": \\\"golangci-lint\\\",\\n  \\\"go.toolsManagement.autoUpdate\\\": true,\\n  \\\"go.useLanguageServer\\\": true,\\n  \\\"gopls\\\": {\\n    \\\"analyses\\\": {\\n      \\\"fieldalignment\\\": true,\\n      \\\"nilness\\\": true,\\n      \\\"shadow\\\": true,\\n      \\\"staticcheck\\\": true,\\n      \\\"unused_write\\\": true,\\n      \\\"unusedparams\\\": false\\n    },\\n    \\\"formatting.gofumpt\\\": true,\\n    \\\"ui.completion.usePlaceholders\\\": false,\\n    \\\"ui.semanticTokens\\\": true\\n  },\\n  \\\"html.autoClosingTags\\\": true,\\n  \\\"isort.args\\\": [\\n    \\\"--profile\\\",\\n    \\\"black\\\",\\n    \\\"--add\\\",\\n    \\\"from __future__ import annotations\\\"\\n  ],\\n  \\\"javascript.format.semicolons\\\": \\\"insert\\\",\\n  \\\"markdownlint.config\\\": {\\n    \\\"MD001\\\": false,\\n    \\\"MD009\\\": false,\\n    \\\"MD013\\\": false,\\n    \\\"MD024\\\": false,\\n    \\\"MD029\\\": false,\\n    \\\"MD033\\\": false,\\n    \\\"MD034\\\": false,\\n    \\\"MD036\\\": false,\\n    \\\"MD038\\\": false,\\n    \\\"MD041\\\": false,\\n    \\\"MD046\\\": false\\n  },\\n  \\\"material-icon-theme.files.associations\\\": {\\n    \\\"*.go\\\": \\\"Go_gopher\\\",\\n    \\\"justfile\\\": \\\"Robot\\\",\\n    \\\"requirements.in\\\": \\\"Python-misc\\\",\\n    \\\"requirements.txt\\\": \\\"Python-misc\\\",\\n    \\\"requirements_dev.in\\\": \\\"Python-misc\\\",\\n    \\\"requirements_dev.txt\\\": \\\"Python-misc\\\",\\n    \\\"spokfile\\\": \\\"Robot\\\"\\n  },\\n  \\\"material-icon-theme.folders.color\\\": \\\"#90a4ae\\\",\\n  \\\"notebook.cellToolbarLocation\\\": {\\n    \\\"default\\\": \\\"right\\\",\\n    \\\"jupyter-notebook\\\": \\\"left\\\"\\n  },\\n  \\\"python.analysis.autoImportCompletions\\\": true,\\n  \\\"python.analysis.completeFunctionParens\\\": false,\\n  \\\"python.analysis.diagnosticMode\\\": \\\"openFilesOnly\\\",\\n  \\\"python.analysis.typeCheckingMode\\\": \\\"strict\\\",\\n  \\\"python.formatting.provider\\\": \\\"none\\\",\\n  \\\"python.languageServer\\\": \\\"Pylance\\\",\\n  \\\"python.linting.enabled\\\": true,\\n  \\\"python.linting.lintOnSave\\\": true,\\n  \\\"python.linting.mypyEnabled\\\": true,\\n  \\\"python.terminal.activateEnvInCurrentTerminal\\\": true,\\n  \\\"python.terminal.activateEnvironment\\\": true,\\n  \\\"redhat.telemetry.enabled\\\": false,\\n  \\\"rust-analyzer.inlayHints.chainingHints.enable\\\": false,\\n  \\\"rust-analyzer.inlayHints.closingBraceHints.enable\\\": false,\\n  \\\"search.exclude\\\": {\\n    \\\"**/*.code-search\\\": true,\\n    \\\"**/*.venv\\\": true,\\n    \\\"**/*venv\\\": true,\\n    \\\"**/bower_components\\\": true,\\n    \\\"**/lib\\\": true,\\n    \\\"**/node_modules\\\": true\\n  },\\n  \\\"shellformat.effectLanguages\\\": [\\n    \\\"shellscript\\\",\\n    \\\"hosts\\\",\\n    \\\"jvmoptions\\\",\\n    \\\"spring-boot-properties\\\",\\n    \\\"azcli\\\"\\n  ],\\n  \\\"terminal.integrated.cursorBlinking\\\": true,\\n  \\\"terminal.integrated.cursorStyle\\\": \\\"line\\\",\\n  \\\"terminal.integrated.enablePersistentSessions\\\": false,\\n  \\\"terminal.integrated.fontFamily\\\": \\\"SFMono Nerd Font\\\",\\n  \\\"terminal.integrated.shell.osx\\\": \\\"/usr/local/bin/fish\\\",\\n  \\\"todo-tree.filtering.ignoreGitSubmodules\\\": true,\\n  \\\"todo-tree.filtering.useBuiltInExcludes\\\": \\\"file and search excludes\\\",\\n  \\\"todo-tree.general.showActivityBarBadge\\\": false,\\n  \\\"todo-tree.general.tags\\\": [\\n    \\\"FIXME\\\",\\n    \\\"TODO\\\",\\n    \\\"todo!\\\"\\n  ],\\n  \\\"todo-tree.highlights.customHighlight\\\": {\\n    \\\"FIXME\\\": {\\n      \\\"fontStyle\\\": \\\"italic\\\",\\n      \\\"foreground\\\": \\\"#ae7be8\\\"\\n    },\\n    \\\"TODO\\\": {\\n      \\\"fontStyle\\\": \\\"italic\\\",\\n      \\\"foreground\\\": \\\"#ae7be8\\\"\\n    },\\n    \\\"todo!\\\": {\\n      \\\"foreground\\\": \\\"#F5FAFF\\\"\\n    }\\n  },\\n  \\\"todo-tree.highlights.enabled\\\": true,\\n  \\\"todo-tree.regex.regex\\\": \\\"(//|#|<!--|;|/\\\\\\\\*|^|^\\\\\\\\s*(-|\\\\\\\\d+.))\\\\\\\\s*($TAGS)\\\",\\n  \\\"todo-tree.ripgrep.ripgrep\\\": \\\"/usr/local/bin/rg\\\",\\n  \\\"todo-tree.tree.expanded\\\": false,\\n  \\\"todo-tree.tree.flat\\\": false,\\n  \\\"todo-tree.tree.tagsOnly\\\": true,\\n  \\\"typescript.format.semicolons\\\": \\\"insert\\\",\\n  \\\"vsintellicode.features.python.deepLearning\\\": \\\"enabled\\\",\\n  \\\"vsintellicode.java.completionsEnabled\\\": false,\\n  \\\"vsintellicode.typescript.completionsEnabled\\\": true,\\n  \\\"workbench.colorCustomizations\\\": {\\n    \\\"[Ariake Dark]\\\": {\\n      \\\"editorBracketHighlight.foreground1\\\": \\\"#ABBFF2\\\",\\n      \\\"editorBracketHighlight.foreground2\\\": \\\"#F993BA\\\",\\n      \\\"editorBracketHighlight.foreground3\\\": \\\"#DDA3F7\\\",\\n      \\\"editorBracketHighlight.foreground4\\\": \\\"#D3B2FF\\\",\\n      \\\"editorBracketHighlight.foreground5\\\": \\\"#B6D5F3\\\",\\n      \\\"editorBracketHighlight.foreground6\\\": \\\"#9AEFEA\\\",\\n      \\\"editorBracketHighlight.unexpectedBracket.foreground\\\": \\\"#F1487B\\\",\\n      \\\"editorInlayHint.background\\\": \\\"#0017191f\\\",\\n      \\\"editorInlayHint.foreground\\\": \\\"#9AEFEA\\\"\\n    }\\n  },\\n  \\\"workbench.colorTheme\\\": \\\"Ariake Dark\\\",\\n  \\\"workbench.editor.enablePreview\\\": false,\\n  \\\"workbench.editor.languageDetection\\\": false,\\n  \\\"workbench.editorAssociations\\\": {\\n    \\\"*.ipynb\\\": \\\"jupyter-notebook\\\"\\n  },\\n  \\\"workbench.fontAliasing\\\": \\\"auto\\\",\\n  \\\"workbench.iconTheme\\\": \\\"material-icon-theme\\\",\\n  \\\"workbench.settings.editor\\\": \\\"json\\\",\\n  \\\"workbench.settings.openDefaultSettings\\\": true,\\n  \\\"workbench.settings.useSplitJSON\\\": true,\\n  \\\"workbench.startupEditor\\\": \\\"none\\\"\\n}\"}","keybindings":"{\"keybindings\":\"// Place your key bindings in this file to override the defaults\\n[\\n    {\\n        \\\"key\\\": \\\"cmd+n\\\",\\n        \\\"command\\\": \\\"extension.advancedNewFile\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"cmd+n\\\",\\n        \\\"command\\\": \\\"workbench.action.terminal.new\\\",\\n        \\\"when\\\": \\\"terminalProcessSupported && terminalFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"cmd+]\\\",\\n        \\\"command\\\": \\\"editor.action.blockComment\\\",\\n        \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n    }\\n]\",\"platform\":1}","snippets":"{\"snippets\":{\"fish.json\":\"{\\n\\t// Place your snippets for fish here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"shebang\\\": {\\n\\t\\t\\\"prefix\\\": \\\"shebang\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#!/usr/bin/env fish\\\\n\\\\n$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts safe fish shebang line after a #!\\\"\\n\\t},\\n\\t\\\"function\\\": {\\n\\t\\t\\\"prefix\\\": \\\"func\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"function ${1:name} --description \\\\\\\"${2:description}.\\\\\\\"\\\",\\n\\t\\t\\t\\\"\\\\targparse --min-args ${3:min_args} --max-args ${4:max_args} h/help -- \\\\\\\\$argv\\\",\\n\\t\\t\\t\\\"\\\\tor return 1\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"\\\\tif set -q _flag_help\\\",\\n\\t\\t\\t\\\"\\\\t\\\\techo \\\\\\\"${2:description}\\\\\\\"\\\",\\n\\t\\t\\t\\\"\\\\t\\\\techo\\\",\\n\\t\\t\\t\\\"\\\\t\\\\techo (set_color --bold)\\\\\\\"Usage:\\\\\\\"(set_color normal)\\\",\\n\\t\\t\\t\\\"\\\\t\\\\techo \\\\\\\"\\\\t${1:name}\\\\\\\"\\\",\\n\\t\\t\\t\\\"\\\\t\\\\techo\\\",\\n\\t\\t\\t\\\"\\\\t\\\\techo (set_color --bold)\\\\\\\"Flags:\\\\\\\"(set_color normal)\\\",\\n\\t\\t\\t\\\"\\\\t\\\\techo \\\\\\\"\\\\t[-h/--help]: Show this help message and exit.\\\\\\\"\\\",\\n\\t\\t\\t\\\"\\\\t\\\\techo\\\",\\n\\t\\t\\t\\\"\\\\t\\\\treturn 0\\\",\\n\\t\\t\\t\\\"\\\\tend\\\",\\n\\t\\t\\t\\\"\\\\t# Function body goes here\\\",\\n\\t\\t\\t\\\"\\\\t$0\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"end\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a generic fish function template.\\\"\\n\\t},\\n\\t\\\"alias\\\": {\\n\\t\\t\\\"prefix\\\": \\\"alias\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"function ${1:name} --wraps=\\\\\\\"${2:wraps}\\\\\\\" --description \\\\\\\"${3:description}\\\\\\\"\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"\\\\tcommand ${4:code_here}\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"end\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a fish alias function template.\\\"\\n\\t}\\n}\",\"go.json\":\"{\\n\\t// Place your snippets for go here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"func main\\\": {\\n\\t\\t\\\"prefix\\\": \\\"main\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"func main() {\\\",\\n\\t\\t\\t\\\"\\\\t$0\\\",\\n\\t\\t\\t\\\"}\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Main Goroutine declaration.\\\"\\n\\t},\\n\\t\\\"if got\\\": {\\n\\t\\t\\\"prefix\\\": \\\"ifgot\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"if got != want {\\\",\\n\\t\\t\\t\\\"\\\\tt.Errorf(\\\\\\\"got %v, wanted %v\\\\\\\", got, want)\\\",\\n\\t\\t\\t\\\"}\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Testing got != want snippet.\\\"\\n\\t}\\n}\",\"python.json\":\"{\\n\\t// Place your snippets for python here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"Author Docstring\\\": {\\n\\t\\t\\\"prefix\\\": \\\"~doc\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"$BLOCK_COMMENT_START\\\",\\n\\t\\t\\t\\\"$1\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"Author: Tom Fleet\\\",\\n\\t\\t\\t\\\"Created: $CURRENT_DATE/$CURRENT_MONTH/$CURRENT_YEAR\\\",\\n\\t\\t\\t\\\"$BLOCK_COMMENT_END\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"$0\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts the Author auto docstring at the top of a script\\\"\\n\\t},\\n\\t\\\"name == main\\\": {\\n\\t\\t\\\"prefix\\\": \\\"~main\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"if __name__ == \\\\\\\"__main__\\\\\\\":\\\",\\n\\t\\t\\t\\\"\\\\t$1\\\",\\n\\t\\t\\t\\\"$0\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts the name == main clause\\\"\\n\\t},\\n\\t\\\"repr\\\": {\\n\\t\\t\\\"prefix\\\": \\\"__repr\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"def __repr__(self) -> str:\\\",\\n\\t\\t\\t\\\"\\\\treturn self.__class__.__qualname__ + f\\\\\\\"($0={})\\\\\\\"\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a generalisable repr method.\\\"\\n\\t},\\n\\t\\\"str\\\": {\\n\\t\\t\\\"prefix\\\": \\\"__str\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"def __str__(self) -> str:\\\",\\n\\t\\t\\t\\\"\\\\treturn $0\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a generalisable str method.\\\"\\n\\t},\\n\\t\\\"init\\\": {\\n\\t\\t\\\"prefix\\\": \\\"__init\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"def __init__(self, $0) -> None:\\\",\\n\\t\\t\\t\\\"\\\\t\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a generalisable init method.\\\"\\n\\t},\\n\\t\\\"Custom Exception\\\": {\\n\\t\\t\\\"prefix\\\": \\\"~exc\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"class $1(Exception):\\\",\\n\\t\\t\\t\\\"\\\\tdef __init__(self, message: str) -> None:\\\",\\n\\t\\t\\t\\\"\\\\t\\\\tself.message = message\\\",\\n\\t\\t\\t\\\"\\\\t\\\\tsuper().__init__(self.message)\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"$0\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a generalisable custom exception class.\\\"\\n\\t},\\n\\t\\\"Shebang\\\": {\\n\\t\\t\\\"prefix\\\": \\\"shebang\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#!/usr/bin/env python3\\\\n\\\\n$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a python3 shebang line.\\\"\\n\\t},\\n}\",\"rust.json\":\"{\\n\\t// Place your snippets for rust here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"Derive\\\": {\\n\\t\\t\\\"prefix\\\": \\\"derive\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[derive($1)]$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Insert a derive macro\\\"\\n\\t},\\n\\t\\\"Config\\\": {\\n\\t\\t\\\"prefix\\\": \\\"cfg\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[cfg($1)]\\\",\\n\\t\\t\\t\\\"$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a generic config setting\\\"\\n\\t},\\n\\t\\\"Config Test\\\": {\\n\\t\\t\\\"prefix\\\": \\\"tests\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[cfg(test)]\\\",\\n\\t\\t\\t\\\"mod test {\\\",\\n\\t\\t\\t\\\"\\\\tuse super::*;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"\\\\t#[test]\\\",\\n\\t\\t\\t\\\"\\\\tfn $1() {\\\",\\n\\t\\t\\t\\\"\\\\t\\\\t$0;\\\",\\n\\t\\t\\t\\\"\\\\t}\\\",\\n\\t\\t\\t\\\"}\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Adds a test group\\\"\\n\\t},\\n\\t\\\"Test\\\": {\\n\\t\\t\\\"prefix\\\": \\\"test\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[test]\\\",\\n\\t\\t\\t\\\"fn $1() {\\\",\\n\\t\\t\\t\\\"\\\\t$0;\\\",\\n\\t\\t\\t\\\"}\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Adds a single unit test\\\"\\n\\t},\\n\\t\\\"Clap\\\": {\\n\\t\\t\\\"prefix\\\": \\\"clap\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[clap($1)]\\\",\\n\\t\\t\\t\\\"$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a generic clap macro statement\\\"\\n\\t},\\n\\t\\\"Command\\\": {\\n\\t\\t\\\"prefix\\\": \\\"command\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[command($1)]\\\",\\n\\t\\t\\t\\\"$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a clap command macro statement\\\"\\n\\t},\\n\\t\\\"Arg\\\": {\\n\\t\\t\\\"prefix\\\": \\\"arg\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[arg($1)]\\\",\\n\\t\\t\\t\\\"$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a clap arg macro statement\\\"\\n\\t},\\n\\t\\\"Cli\\\": {\\n\\t\\t\\\"prefix\\\": \\\"cli\\\",\\n\\t\\t\\\"description\\\": \\\"Inserts the clap derive API CLI boilerplate\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#[derive(Parser, Debug)]\\\",\\n\\t\\t\\t\\\"#[clap(author, version, about, long_about = None)]\\\",\\n\\t\\t\\t\\\"struct Cli {}\\\"\\n\\t\\t]\\n\\t},\\n\\t\\\"Docs\\\": {\\n\\t\\t\\\"prefix\\\": \\\"doc\\\",\\n\\t\\t\\\"description\\\": \\\"Add a doc macro statement\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#![doc = include_str!(\\\\\\\"../README.md\\\\\\\")]\\\"\\n\\t\\t]\\n\\t},\\n\\t\\\"Pedantic\\\": {\\n\\t\\t\\\"prefix\\\": \\\"pedantic\\\",\\n\\t\\t\\\"description\\\": \\\"Insert a clippy pedantic attribute\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#![warn(clippy::pedantic)]\\\"\\n\\t\\t]\\n\\t}\\n}\",\"shellscript.json\":\"{\\n\\t// Place your snippets for shellscript here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"shebang\\\": {\\n\\t\\t\\\"prefix\\\": \\\"shebang\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#!/usr/bin/env zsh\\\\n\\\\n$0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts safe zsh shebang line after a #!\\\"\\n\\t}\\n}\",\"tom_snips.code-snippets\":\"{\\n\\t// Place your global snippets here. Each snippet is defined under a snippet name and has a scope, prefix, body and \\n\\t// description. Add comma separated ids of the languages where the snippet is applicable in the scope field. If scope \\n\\t// is left empty or omitted, the snippet gets applied to all languages. The prefix is what is \\n\\t// used to trigger the snippet and the body will be expanded and inserted. Possible variables are: \\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. \\n\\t// Placeholders with the same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"scope\\\": \\\"javascript,typescript\\\",\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"TODO\\\": {\\n\\t\\t\\\"prefix\\\": \\\"todo\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"$LINE_COMMENT TODO: $0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a comment: TODO.\\\"\\n\\t},\\n\\t\\\"FIXME\\\": {\\n\\t\\t\\\"prefix\\\": \\\"fixme\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"$LINE_COMMENT FIXME: $0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a comment: FIXME.\\\"\\n\\t},\\n\\t\\\"BUG\\\": {\\n\\t\\t\\\"prefix\\\": \\\"bug\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"$LINE_COMMENT BUG: $0\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Inserts a comment: FIXME.\\\"\\n\\t}\\n}\"}}","extensions":"[{\"identifier\":{\"id\":\"bierner.github-markdown-preview\",\"uuid\":\"9f5a5fc9-8b23-4484-85c4-1438b82d8634\"},\"displayName\":\"GitHub Markdown Preview\"},{\"identifier\":{\"id\":\"bierner.markdown-checkbox\",\"uuid\":\"b0db4123-c5d9-4f45-bd2e-70738ebbb304\"},\"displayName\":\"Markdown Checkboxes\"},{\"identifier\":{\"id\":\"bierner.markdown-emoji\",\"uuid\":\"f595c9c1-28b5-415e-a55f-2deb4a8c3abd