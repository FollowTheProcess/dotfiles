<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>my.startup</string>
  <key>ProgramArguments</key>
  <array>
    <string>sh</string>
    <string>-c</string>
    <string>
    <!-- Set XDG_CONFIG_HOME globally on start up, before any shell settings have been applied -->
    launchctl setenv XDG_CONFIG_HOME /Users/tomfleet/.config
    </string>        
  </array>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
